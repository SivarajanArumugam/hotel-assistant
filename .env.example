# Groq API — required
GROQ_API_KEY=your_groq_api_key_here

# LLM model — do not change unless you know what you are doing
LLM_MODEL=llama-3.3-70b-versatile

# RAG — vector store location
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=hotel_docs

# PDF document — folder where the hotel PDF lives (do not include filename)
DATA_FOLDER=./data

# Embedding model (HuggingFace, downloaded automatically on first run)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Number of final chunks returned to the LLM
TOP_K_RETRIEVAL=3

# Database — SQLite file path
DATABASE_URL=sqlite:///./hotel.db

# Logging level
LOG_LEVEL=INFO

# Encryption key for guest PII — auto-generated and written here on first run
# Do not set this manually. Leave it absent and the app will create it.
# FERNET_KEY=
